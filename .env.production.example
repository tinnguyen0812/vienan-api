# ─── Database ────────────────────────────────────────────────────────────────
DATABASE_URL=postgresql://postgres:PASSWORD@HOST:5432/vienan_prod

# ─── Auth ─────────────────────────────────────────────────────────────────────
# Generate: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=CHANGE_ME_TO_64_CHAR_RANDOM_STRING
JWT_EXPIRES_IN=7d

# ─── App ──────────────────────────────────────────────────────────────────────
PORT=3000
NODE_ENV=production

# ─── CORS ─────────────────────────────────────────────────────────────────────
ALLOWED_ORIGINS=https://vienan.com,https://admin.vienan.com
