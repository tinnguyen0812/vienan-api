# ─── Database (Neon free tier) ───────────────────────────────────────────────
# Lấy từ: https://console.neon.tech → Project → Connection Details
DATABASE_URL=postgresql://[user]:[password]@[host].neon.tech/vienan_uat?sslmode=require

# ─── Auth ─────────────────────────────────────────────────────────────────────
JWT_SECRET=uat-secret-change-before-production
JWT_EXPIRES_IN=7d

# ─── App ──────────────────────────────────────────────────────────────────────
PORT=3000
NODE_ENV=production

# ─── CORS (Vercel preview URLs + localhost) ────────────────────────────────────
ALLOWED_ORIGINS=https://vienan-storefront.vercel.app,https://vienan-admin.vercel.app,http://localhost:5173,http://localhost:5174
